@model List<CaisseSession>
@{
    ViewData["Title"] = "Caisses";
    var ouvertes = ViewBag.CaissesOuvertes as List<CaisseSession> ?? new();
    var mouvParCaisse = ViewBag.MouvementsParCaisse as Dictionary<int, List<MouvementCaisse>> ?? new();
    var ventesParCaisse = ViewBag.VentesParModeParCaisse as Dictionary<int, List<object>> ?? new();
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">Caisses</h1>
    <span class="badge bg-success fs-6">@ouvertes.Count ouverte(s)</span>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Ouvrir une caisse</h5>
                <form asp-action="Ouvrir" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2"><label class="form-label">Nom de la caisse</label><input name="libelle" class="form-control" value="Caisse" placeholder="Bar, Terrasse, Caisse 2..." /></div>
                    <div class="mb-3"><label class="form-label">Fond de caisse (espèces)</label><input name="montantOuverture" type="number" step="1" min="0" class="form-control" value="0" /></div>
                    <button class="btn btn-primary w-100">Ouvrir</button>
                </form>
                <p class="text-muted small mt-2 mb-0">Plusieurs caisses peuvent être ouvertes en même temps (par point de vente ou par caissier).</p>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        @if (!ouvertes.Any())
        {
            <div class="alert alert-warning">Aucune caisse ouverte actuellement.</div>
        }
        @foreach (var caisse in ouvertes)
        {
            var mouvements = mouvParCaisse.TryGetValue(caisse.Id, out var lm) ? lm : new List<MouvementCaisse>();
            var modes = ventesParCaisse.TryGetValue(caisse.Id, out var vm) ? vm : new List<object>();
            <div class="card mb-4 border-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="fw-bold mb-1"><i class="bi bi-cash-stack me-1"></i> @caisse.Libelle</h5>
                            <div class="text-muted small">@caisse.Caissier · ouverte le @caisse.DateOuverture.ToString("dd/MM HH:mm")</div>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small">Solde théorique (espèces)</div>
                            <div class="fs-4 fw-bold">@String.Format("{0:N0} FCFA", caisse.SoldeTheorique)</div>
                        </div>
                    </div>

                    <div class="row text-center my-3 g-2">
                        <div class="col"><div class="text-muted small">Fond</div><strong>@String.Format("{0:N0}", caisse.MontantOuverture)</strong></div>
                        <div class="col"><div class="text-muted small">Encaiss. espèces</div><strong>@String.Format("{0:N0}", caisse.Encaissements)</strong></div>
                        <div class="col"><div class="text-muted small">Autres modes</div><strong>@String.Format("{0:N0}", caisse.EncaissementsAutres)</strong></div>
                        <div class="col"><div class="text-muted small">Décaiss.</div><strong>@String.Format("{0:N0}", caisse.Decaissements)</strong></div>
                    </div>

                    @if (modes.Any())
                    {
                        <div class="small text-muted mb-1">Ventes par mode :</div>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (dynamic m in modes)
                            {
                                <span class="badge bg-light text-dark border">@m.Mode : @String.Format("{0:N0}", m.Total) (@m.Nombre)</span>
                            }
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-md-6">
                            <form asp-action="Mouvement" method="post" class="border rounded p-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="caisseId" value="@caisse.Id" />
                                <div class="fw-semibold small mb-2">Apport / Retrait</div>
                                <div class="mb-2"><select name="type" class="form-select form-select-sm">
                                    <option value="@((int)TypeMouvementCaisse.Apport)">Apport</option>
                                    <option value="@((int)TypeMouvementCaisse.Retrait)">Retrait</option>
                                </select></div>
                                <div class="mb-2"><input name="montant" type="number" min="1" class="form-control form-control-sm" placeholder="Montant" required /></div>
                                <div class="mb-2"><input name="motif" class="form-control form-control-sm" placeholder="Motif" required /></div>
                                <button class="btn btn-sm btn-outline-primary w-100">Enregistrer</button>
                            </form>
                        </div>
                        <div class="col-md-6">
                            <form asp-action="Fermer" method="post" class="border rounded p-2" onsubmit="return confirm('Clôturer cette caisse ?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="caisseId" value="@caisse.Id" />
                                <div class="fw-semibold small mb-2">Clôturer</div>
                                <div class="mb-2"><input name="montantCloture" type="number" min="0" class="form-control form-control-sm" value="@((long)caisse.SoldeTheorique)" placeholder="Montant compté" /></div>
                                <div class="mb-2"><textarea name="commentaireCloture" class="form-control form-control-sm" rows="2" placeholder="Justification si écart"></textarea></div>
                                <button class="btn btn-sm btn-danger w-100">Clôturer</button>
                            </form>
                        </div>
                    </div>

                    @if (mouvements.Any())
                    {
                        <details class="mt-3">
                            <summary class="small text-muted">@mouvements.Count mouvement(s)</summary>
                            <ul class="list-unstyled small mt-2 mb-0">
                                @foreach (var m in mouvements)
                                {
                                    <li>@m.DateMouvement.ToString("dd/MM HH:mm") — @(m.Type == TypeMouvementCaisse.ReglementCredit ? "Règlement crédit" : m.Type.ToString()) : @String.Format("{0:N0}", m.Montant) (@m.Motif)</li>
                                }
                            </ul>
                        </details>
                    }
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body table-responsive">
                <h5 class="fw-bold mb-3">Historique des caisses clôturées</h5>
                <table class="table align-middle">
                    <thead><tr><th>Caisse</th><th>Ouverture</th><th>Caissier</th><th class="text-end">CA total</th><th class="text-end">Solde théo.</th><th class="text-end">Écart</th><th>Justif.</th></tr></thead>
                    <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.Libelle</td>
                            <td>@c.DateOuverture.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@c.Caissier</td>
                            <td class="text-end">@String.Format("{0:N0} FCFA", c.ChiffreAffaires)</td>
                            <td class="text-end">@String.Format("{0:N0} FCFA", c.SoldeTheorique)</td>
                            <td class="text-end @(c.Ecart.HasValue && c.Ecart.Value != 0 ? "text-danger fw-bold" : "")">@(c.Ecart.HasValue ? String.Format("{0:N0}", c.Ecart.Value) : "-")</td>
                            <td class="small text-muted">@c.CommentaireCloture</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
