@model List<Depense>
@{
    ViewData["Title"] = "Dépenses";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="fw-bold mb-1">Dépenses</h1><p class="text-muted mb-0">Suivi des charges et décaissements.</p></div>
    <a asp-action="Nouvelle" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Ajouter</a>
</div>
<div class="card"><div class="card-body table-responsive">
    <table class="table align-middle">
        <thead><tr><th>Date</th><th>Libellé</th><th>Catégorie</th><th>Bénéficiaire</th><th class="text-end">Montant</th><th class="text-end">Actions</th></tr></thead>
        <tbody>@foreach (var d in Model){<tr><td>@d.DateDepense.ToString("dd/MM/yyyy")</td><td class="fw-semibold">@d.Libelle</td><td>@d.Categorie</td><td>@d.Beneficiaire</td><td class="text-end fw-bold">@String.Format("{0:N0} FCFA", d.Montant)</td><td class="text-end"><a asp-action="Modifier" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary">Modifier</a><form asp-action="Supprimer" asp-route-id="@d.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer cette dépense ?')">Supprimer</button></form></td></tr>}</tbody>
    </table>
</div></div>
