@{
    ViewData["Title"] = "Connexion";
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <title>Connexion - LP2M APPS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
    <link rel="manifest" href="~/manifest.json">
    <meta name="theme-color" content="#165DFF">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <link rel="apple-touch-icon" href="~/img/app/apple-touch-icon.png">
</head>
<body class="login-page">
    <div class="login-card card shadow-lg">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <div class="login-icon"><i class="bi bi-cup-hot-fill"></i></div>
                <h3 class="fw-bold mt-3">LP2M APPS</h3>
                <p class="text-muted mb-0">Multi-tenant, QR code, panier rapide</p>
            </div>

            @if (ViewBag.Erreur != null)
            {
                <div class="alert alert-danger">@ViewBag.Erreur</div>
            }
            @if (TempData["Erreur"] != null)
            {
                <div class="alert alert-danger">@TempData["Erreur"]</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Identifiant</label>
                    <input type="text" name="login" class="form-control form-control-lg" required autofocus />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mot de passe</label>
                    <input type="password" name="motdepasse" class="form-control form-control-lg" required />
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100">Se connecter</button>
            </form>

            <div class="login-divider"><span>ou</span></div>
            @if (ViewBag.GoogleActive == true)
            {
                <a asp-controller="Auth" asp-action="GoogleLogin" class="btn btn-light border btn-lg w-100 google-btn">
                    <i class="bi bi-google me-2"></i> Continuer avec Google
                </a>
            }
            else
            {
                <button type="button" class="btn btn-light border btn-lg w-100 google-btn" disabled title="Renseignez ClientId et ClientSecret dans appsettings ou variables d'environnement.">
                    <i class="bi bi-google me-2"></i> Continuer avec Google
                </button>
                <div class="form-text text-center mt-1">Google Login prêt, configuration OAuth à renseigner.</div>
            }

            @if (TempData["Succes"] != null)
            {
                <div class="alert alert-success mt-3 mb-0">@TempData["Succes"]</div>
            }
            <div class="text-center mt-3">
                <span class="text-muted">Pas encore de compte ?</span>
                <a asp-controller="Auth" asp-action="Inscription">Inscrire mon établissement</a>
            </div>

        </div>
    </div>
</body>
</html>
