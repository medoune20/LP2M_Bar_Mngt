@{
    ViewData["Title"] = "Inscription";
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <title>Inscription - LP2M APPS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
</head>
<body class="login-page">
    <div class="login-container">
        <div class="login-card" style="max-width:480px;">
            <h3 class="fw-bold mb-1">Inscrire mon établissement</h3>
            <p class="text-muted">Votre compte sera activé par l'administrateur après vérification.</p>

            @if (ViewBag.Erreur != null)
            {
                <div class="alert alert-danger">@ViewBag.Erreur</div>
            }

            @if (ViewBag.GoogleActive == true)
            {
                <a asp-controller="Auth" asp-action="GoogleLogin" class="btn btn-light border btn-lg w-100 google-btn mb-3">
                    <i class="bi bi-google me-2"></i> Continuer avec Google
                </a>
                <div class="login-divider"><span>ou formulaire classique</span></div>
            }
            else
            {
                <button type="button" class="btn btn-light border btn-lg w-100 google-btn mb-2" disabled>
                    <i class="bi bi-google me-2"></i> Continuer avec Google
                </button>
                <div class="form-text text-center mb-3">Google Login prêt, configuration OAuth à renseigner.</div>
            }

            <form asp-action="Inscription" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-2"><label class="form-label">Nom de l'établissement</label><input name="etablissement" class="form-control" required /></div>
                <div class="mb-2"><label class="form-label">Ville</label><input name="ville" class="form-control" /></div>
                <hr />
                <div class="mb-2"><label class="form-label">Votre nom complet</label><input name="nomComplet" class="form-control" required /></div>
                <div class="mb-2"><label class="form-label">Email</label><input name="email" type="email" class="form-control" required /></div>
                <div class="mb-2"><label class="form-label">Identifiant de connexion</label><input name="login" class="form-control" autocomplete="username" required /></div>
                <div class="mb-2">
                    <label class="form-label">Mot de passe</label>
                    <input name="motdepasse" id="motdepasse" type="password" class="form-control" autocomplete="new-password" minlength="8" required />
                    <div class="form-text">Au moins 8 caractères, avec une majuscule, une minuscule, un chiffre et un caractère spécial.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirmer le mot de passe</label>
                    <input name="motdepasseConfirmation" id="motdepasseConfirmation" type="password" class="form-control" autocomplete="new-password" required />
                    <div class="form-text text-danger d-none" id="erreurConfirmation">Les deux mots de passe ne correspondent pas.</div>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100">Créer ma demande</button>
            </form>

            <div class="text-center mt-3">
                <a asp-controller="Auth" asp-action="Connexion">J'ai déjà un compte</a>
            </div>
        </div>
    </div>
    <script>
        (function () {
            var mdp = document.getElementById('motdepasse');
            var conf = document.getElementById('motdepasseConfirmation');
            var msg = document.getElementById('erreurConfirmation');
            if (!mdp || !conf) return;
            function verifier() {
                var differe = conf.value.length > 0 && conf.value !== mdp.value;
                conf.setCustomValidity(differe ? 'Les deux mots de passe ne correspondent pas.' : '');
                if (msg) msg.classList.toggle('d-none', !differe);
            }
            mdp.addEventListener('input', verifier);
            conf.addEventListener('input', verifier);
        })();
    </script>
</body>
</html>
