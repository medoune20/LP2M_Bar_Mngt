@{
    var role = Context.Session.GetInt32("UtilisateurRole") ?? 0;
    var nom = Context.Session.GetString("UtilisateurNom") ?? "Utilisateur";
    var tenantNom = Context.Session.GetString("TenantNom") ?? "Tenant";
    var tenantCode = Context.Session.GetString("TenantCode") ?? "TENANT";
    var tenantColor = Context.Session.GetString("TenantColor") ?? "#165DFF";
    var isSuperAdmin = Context.Session.GetString("IsSuperAdmin") == "true";
    bool estAdmin = role == 1;
    bool estManager = role == 3;
    var perms = Context.Session.GetString("Permissions") ?? "";
    var aProfil = (Context.Session.GetInt32("ProfilAccesId") ?? 0) > 0;
    Func<string, bool> voir = m => Domaine.ModulesApp.Autorise(isSuperAdmin, role, perms, aProfil, m, false);
    var refus = Context.Session.GetString("AccesRefuse");
    Context.Session.Remove("AccesRefuse");
}
<!DOCTYPE html>
<html lang="fr" style="--tenant-color:@tenantColor">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestion Bar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
    <link rel="manifest" href="~/manifest.json">
    <meta name="theme-color" content="@tenantColor">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <link rel="apple-touch-icon" href="~/img/app/apple-touch-icon.png">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar sticky-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" asp-controller="Accueil" asp-action="Index">
                <i class="bi bi-cup-hot-fill me-2"></i> Gestion Bar
            </a>
            <span class="tenant-pill me-3">@tenantCode - @tenantNom</span>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="menuPrincipal">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Accueil" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Chat" asp-action="Index"><i class="bi bi-chat-dots me-1"></i> Messagerie</a></li>
                    @if (voir("caisse_rapide"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Vente" asp-action="Rapide"><i class="bi bi-lightning-charge me-1"></i> Caisse rapide</a></li>
                    }
                    @if (voir("ventes"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Vente" asp-action="Index"><i class="bi bi-receipt me-1"></i> Ventes</a></li>
                    }
                    @if (voir("caisse"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Caisse" asp-action="Index"><i class="bi bi-cash-stack me-1"></i> Caisse</a></li>
                    }
                    @if (voir("produits"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Produit" asp-action="Index"><i class="bi bi-box-seam me-1"></i> Produits</a></li>
                    }
                    @if (voir("categories"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Categorie" asp-action="Index"><i class="bi bi-tags me-1"></i> Catégories</a></li>
                    }
                    @if (voir("stock"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Stock" asp-action="Index"><i class="bi bi-boxes me-1"></i> Stock</a></li>
                    }
                    @if (voir("clients"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Client" asp-action="Index"><i class="bi bi-person-lines-fill me-1"></i> Clients</a></li>
                    }
                    @if (voir("fidelite"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Fidelite" asp-action="Index"><i class="bi bi-stars me-1"></i> Fidélité</a></li>
                    }
                    @if (voir("depenses"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Depense" asp-action="Index"><i class="bi bi-coin me-1"></i> Dépenses</a></li>
                    }
                    @if (voir("rapports"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Rapport" asp-action="Index"><i class="bi bi-graph-up me-1"></i> Rapports</a></li>
                    }
                    @if (voir("previsions"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Prevision" asp-action="Index"><i class="bi bi-magic me-1"></i> Prévisions</a></li>
                    }
                    @if (voir("evaluation_caissiers"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="EvaluationCaissier" asp-action="Index"><i class="bi bi-award me-1"></i> Caissiers</a></li>
                    }
                    @if (estAdmin || isSuperAdmin)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Utilisateur" asp-action="Index"><i class="bi bi-people me-1"></i> Utilisateurs</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Profil" asp-action="Index"><i class="bi bi-shield-lock me-1"></i> Profils / rôles</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Tenant" asp-action="Modifier" asp-route-id="@(Context.Session.GetInt32("TenantId"))"><i class="bi bi-shop me-1"></i> Mon établissement</a></li>
                    }
                    @if (isSuperAdmin)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Tenant" asp-action="Demandes"><i class="bi bi-person-check me-1"></i> Demandes d'inscription</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Tenant" asp-action="Index"><i class="bi bi-buildings me-1"></i> Tenants</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Sauvegarde" asp-action="Index"><i class="bi bi-database-down me-1"></i> Sauvegarde</a></li>
                    }
                </ul>
                <span class="navbar-text text-white me-3"><i class="bi bi-person-circle me-1"></i> @nom</span>
                <form asp-controller="Auth" asp-action="Deconnexion" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-light btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i> Déconnexion
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container-fluid px-4 py-4">
        @if (TempData["Succes"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Succes"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Erreur"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Erreur"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (refus != null)
        {
            <div class="alert alert-warning alert-dismissible fade show">
                @refus
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <!-- Navigation mobile (téléphones / petites tablettes) -->
    <nav class="mobile-bottom-nav d-lg-none">
        <a asp-controller="Accueil" asp-action="Index"><i class="bi bi-speedometer2"></i><span>Accueil</span></a>
        <a asp-controller="Chat" asp-action="Index"><i class="bi bi-chat-dots"></i><span>Chat</span></a>
        @if (voir("ventes"))
        {
            <a asp-controller="Vente" asp-action="Index"><i class="bi bi-receipt"></i><span>Ventes</span></a>
        }
        @if (voir("caisse_rapide"))
        {
            <a asp-controller="Vente" asp-action="Rapide" class="mobile-nav-pos"><i class="bi bi-lightning-charge-fill"></i><span>Caisse</span></a>
        }
        @if (voir("stock"))
        {
            <a asp-controller="Stock" asp-action="Index"><i class="bi bi-boxes"></i><span>Stock</span></a>
        }
        @if (voir("caisse"))
        {
            <a asp-controller="Caisse" asp-action="Index"><i class="bi bi-cash-stack"></i><span>Session</span></a>
        }
    </nav>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
