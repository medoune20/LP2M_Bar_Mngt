@model CompteResultatVm
@{
    ViewData["Title"] = "Compte de résultat";
    Func<decimal, string> fcfa = v => string.Format("{0:N0} {1}", v, Model.Devise == "XOF" ? "FCFA" : Model.Devise);
    var du = ViewBag.Du as string;
    var au = ViewBag.Au as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h1 class="fw-bold mb-1">Compte de résultat</h1>
        <p class="text-muted mb-0">SYSCOHADA — du @Model.Du.ToString("dd/MM/yyyy") au @Model.Au.ToString("dd/MM/yyyy") (montants HT)</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index" asp-route-du="@du" asp-route-au="@au"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-arrow-down-circle text-success me-1"></i>Produits (classe 7)</div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <tbody>
                        @if (!Model.Produits.Any()) { <tr><td class="text-muted py-3">Aucun produit.</td><td></td></tr> }
                        @foreach (var p in Model.Produits)
                        {
                            <tr><td>@p.Compte — @p.Intitule</td><td class="text-end">@fcfa(p.Montant)</td></tr>
                        }
                    </tbody>
                    <tfoot><tr class="fw-bold border-top"><td>Total produits</td><td class="text-end">@fcfa(Model.TotalProduits)</td></tr></tfoot>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-arrow-up-circle text-danger me-1"></i>Charges (classe 6)</div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <tbody>
                        @if (!Model.Charges.Any()) { <tr><td class="text-muted py-3">Aucune charge.</td><td></td></tr> }
                        @foreach (var c in Model.Charges)
                        {
                            <tr><td>@c.Compte — @c.Intitule</td><td class="text-end">@fcfa(c.Montant)</td></tr>
                        }
                    </tbody>
                    <tfoot><tr class="fw-bold border-top"><td>Total charges</td><td class="text-end">@fcfa(Model.TotalCharges)</td></tr></tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Résultat net de la période</h4>
        <h4 class="mb-0 @(Model.Resultat >= 0 ? "text-success" : "text-danger")">@fcfa(Model.Resultat)</h4>
    </div>
</div>
