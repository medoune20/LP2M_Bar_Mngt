@{
    ViewData["Title"] = "Sauvegarde";
    bool exists = ViewBag.DbExists == true;
    long size = Convert.ToInt64(ViewBag.DbSize ?? 0);
}
<h1 class="fw-bold mb-4">Sauvegarde</h1>
<div class="card">
    <div class="card-body">
        <h5 class="fw-bold">Base de données SQLite</h5>
        <p class="text-muted">La base est stockée dans le fichier suivant :</p>
        <pre class="bg-light p-3 rounded">@ViewBag.DbPath</pre>
        <div class="mb-3">
            <span class="badge @(exists ? "bg-success" : "bg-danger")">@(exists ? "Base disponible" : "Base introuvable")</span>
            @if (exists) { <span class="ms-2 text-muted">Taille : @String.Format("{0:N0}", size) octets</span> }
        </div>
        <a asp-action="Telecharger" class="btn btn-primary"><i class="bi bi-download me-1"></i> Télécharger la sauvegarde SQLite</a>
    </div>
</div>
