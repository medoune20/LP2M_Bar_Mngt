@model List<Commande>
@{
    ViewData["Title"] = "Cuisine (KDS)";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h1 class="fw-bold mb-1"><i class="bi bi-fire me-2"></i>Cuisine</h1>
        <p class="text-muted mb-0">Articles envoyés en préparation. Actualisation automatique.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Plan de salle</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success"><i class="bi bi-check2-circle me-1"></i>Aucune commande en attente en cuisine.</div>
}

<div class="row g-3">
    @foreach (var c in Model)
    {
        var lignes = c.Lignes.Where(l => l.Preparation == StatutPreparation.EnCuisine || l.Preparation == StatutPreparation.Prete)
            .OrderBy(l => l.Preparation).ToList();
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="bi bi-shop-window me-1"></i>Table @c.TableNom</span>
                    <span class="text-muted small">@c.DateOuverture.ToString("HH:mm") · @c.Couverts couv.</span>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var l in lignes)
                    {
                        var prete = l.Preparation == StatutPreparation.Prete;
                        <li class="list-group-item d-flex justify-content-between align-items-center @(prete ? "bg-light" : "")">
                            <span>
                                <span class="badge @(prete ? "text-bg-success" : "text-bg-warning") me-1">@l.Quantite×</span>
                                <span class="@(prete ? "text-decoration-line-through text-muted" : "fw-semibold")">@l.ProduitNom</span>
                                @if (!string.IsNullOrWhiteSpace(l.Note)) { <div class="small text-muted">@l.Note</div> }
                            </span>
                            <span class="d-flex gap-1">
                                @if (!prete)
                                {
                                    <form asp-action="MarquerLigne" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ligneId" value="@l.Id" />
                                        <input type="hidden" name="statut" value="3" />
                                        <button class="btn btn-sm btn-success" title="Prêt"><i class="bi bi-check2"></i></button>
                                    </form>
                                }
                                <form asp-action="MarquerLigne" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ligneId" value="@l.Id" />
                                    <input type="hidden" name="statut" value="4" />
                                    <button class="btn btn-sm btn-outline-secondary" title="Servi"><i class="bi bi-bag-check"></i></button>
                                </form>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    // Actualisation automatique de l'écran cuisine.
    setTimeout(function(){ location.reload(); }, 25000);
</script>
}
