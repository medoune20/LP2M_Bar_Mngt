@{
    ViewData["Title"] = "Messagerie";
    var utilisateurId = (int)(ViewBag.UtilisateurId ?? 0);
    var tenantNom = ViewBag.TenantNom as string ?? "établissement";
    var salons = ViewBag.Salons as List<SalonsChat.Salon> ?? new List<SalonsChat.Salon>();
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-0"><i class="bi bi-chat-dots-fill me-2"></i>Messagerie de l'équipe</h4>
        <small class="text-muted">Échanges en direct entre les utilisateurs de @tenantNom</small>
    </div>
    <span id="chat-statut" class="badge text-bg-secondary"><i class="bi bi-arrow-repeat me-1"></i>Connexion…</span>
</div>

<div class="row g-3">
    <div class="col-lg-9">
        <div class="card chat-card shadow-sm">
            <div class="chat-salons">
                @foreach (var s in salons)
                {
                    <button type="button" class="chat-salon-tab" data-canal="@s.Cle">
                        <i class="bi @s.Icone me-1"></i>@s.Nom
                        <span class="chat-salon-dot" hidden></span>
                    </button>
                }
            </div>
            <div id="chat-messages" class="chat-messages" aria-live="polite">
                <div id="chat-vide" class="chat-vide text-muted">
                    <i class="bi bi-chat-square-text d-block mb-2" style="font-size:2rem;"></i>
                    Aucun message dans ce salon. Démarrez la conversation !
                </div>
            </div>
            <form id="chat-form" class="chat-form" autocomplete="off">
                <input type="text" id="chat-input" class="form-control" maxlength="2000"
                       placeholder="Écrire un message…" aria-label="Message" disabled />
                <button type="submit" id="chat-envoyer" class="btn btn-primary" disabled>
                    <i class="bi bi-send-fill"></i><span class="d-none d-sm-inline ms-1">Envoyer</span>
                </button>
            </form>
        </div>
    </div>
    <div class="col-lg-3">
        <div class="card shadow-sm chat-presence-card">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-people-fill me-1"></i>En ligne
                <span id="chat-presence-compte" class="badge text-bg-success ms-1">0</span>
            </div>
            <ul id="chat-presence" class="list-group list-group-flush chat-presence"></ul>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .chat-card { overflow: hidden; }
        .chat-salons { display: flex; gap: .25rem; padding: .5rem .5rem 0; background: #fff; flex-wrap: wrap; border-bottom: 1px solid #e6e9ef; }
        .chat-salon-tab { position: relative; border: 1px solid transparent; background: #eef1f6; color: #44506a;
            border-radius: .6rem .6rem 0 0; padding: .4rem .8rem; font-size: .85rem; font-weight: 600; cursor: pointer; }
        .chat-salon-tab.actif { background: var(--tenant-color, #165DFF); color: #fff; }
        .chat-salon-dot { position: absolute; top: 4px; right: 4px; width: 9px; height: 9px; border-radius: 50%; background: #dc3545; }
        .chat-messages { height: 58vh; min-height: 300px; overflow-y: auto; padding: 1rem;
            background: #f6f8fb; display: flex; flex-direction: column; gap: .5rem; }
        .chat-vide { margin: auto; text-align: center; }
        .chat-msg { max-width: 80%; padding: .5rem .75rem; border-radius: .9rem;
            background: #fff; border: 1px solid #e6e9ef; box-shadow: 0 1px 1px rgba(0,0,0,.03); }
        .chat-msg .chat-auteur { font-size: .72rem; font-weight: 700; color: var(--tenant-color, #165DFF); }
        .chat-msg .chat-texte { white-space: pre-wrap; word-break: break-word; }
        .chat-msg .chat-heure { font-size: .68rem; color: #8a93a3; text-align: right; margin-top: .15rem; }
        .chat-msg.moi { align-self: flex-end; background: var(--tenant-color, #165DFF); color: #fff; border-color: transparent; }
        .chat-msg.moi .chat-auteur { color: rgba(255,255,255,.85); }
        .chat-msg.moi .chat-heure { color: rgba(255,255,255,.8); }
        .chat-form { display: flex; gap: .5rem; padding: .75rem; border-top: 1px solid #e6e9ef; background: #fff; }
        .chat-presence-card { position: sticky; top: 5rem; }
        .chat-presence { max-height: 60vh; overflow-y: auto; }
        .chat-presence .puce { width: 9px; height: 9px; border-radius: 50%; background: #28a745; display: inline-block; margin-right: .4rem; }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        (function () {
            const moiId = @utilisateurId;
            const zone = document.getElementById('chat-messages');
            const vide = document.getElementById('chat-vide');
            const form = document.getElementById('chat-form');
            const input = document.getElementById('chat-input');
            const bouton = document.getElementById('chat-envoyer');
            const statut = document.getElementById('chat-statut');
            const tabs = Array.from(document.querySelectorAll('.chat-salon-tab'));
            const presenceListe = document.getElementById('chat-presence');
            const presenceCompte = document.getElementById('chat-presence-compte');
            const urlHub = '@Url.Content("~/hubChat")';
            const urlHistorique = '@Url.Action("Historique", "Chat")';
            const urlMarquerLu = '@Url.Action("MarquerLu", "Chat")';
            const rolesNoms = { 1: 'Admin', 2: 'Caissier', 3: 'Manager' };
            let connecte = false;
            let canalCourant = tabs.length ? tabs[0].dataset.canal : 'general';

            function definirStatut(texte, classe) { statut.className = 'badge ' + classe; statut.innerHTML = texte; }
            function defilerEnBas() { zone.scrollTop = zone.scrollHeight; }

            function viderZone() {
                zone.querySelectorAll('.chat-msg').forEach(e => e.remove());
                if (vide) { zone.appendChild(vide); vide.style.display = ''; }
            }

            function ajouterMessage(m) {
                if (vide) vide.style.display = 'none';
                const bulle = document.createElement('div');
                bulle.className = 'chat-msg' + (Number(m.utilisateurId) === moiId ? ' moi' : '');

                const auteur = document.createElement('div');
                auteur.className = 'chat-auteur';
                auteur.textContent = m.auteur + (rolesNoms[m.role] ? ' · ' + rolesNoms[m.role] : '');

                const texte = document.createElement('div');
                texte.className = 'chat-texte';
                texte.textContent = m.texte; // textContent => protection XSS

                const heure = document.createElement('div');
                heure.className = 'chat-heure';
                heure.textContent = m.heure;

                bulle.appendChild(auteur);
                bulle.appendChild(texte);
                bulle.appendChild(heure);
                zone.appendChild(bulle);
                defilerEnBas();
            }

            function pointSalon(canal, visible) {
                const tab = tabs.find(t => t.dataset.canal === canal);
                if (!tab) return;
                const dot = tab.querySelector('.chat-salon-dot');
                if (dot) dot.hidden = !visible;
            }

            function chargerSalon(canal) {
                canalCourant = canal;
                tabs.forEach(t => t.classList.toggle('actif', t.dataset.canal === canal));
                pointSalon(canal, false);
                viderZone();
                fetch(urlHistorique + '?canal=' + encodeURIComponent(canal), { headers: { 'Accept': 'application/json' } })
                    .then(r => r.ok ? r.json() : [])
                    .then(liste => { (liste || []).forEach(ajouterMessage); })
                    .catch(() => { });
            }

            function rendrePresence(liste) {
                presenceListe.innerHTML = '';
                presenceCompte.textContent = (liste || []).length;
                (liste || []).forEach(u => {
                    const li = document.createElement('li');
                    li.className = 'list-group-item d-flex align-items-center';
                    const puce = document.createElement('span');
                    puce.className = 'puce';
                    const nom = document.createElement('span');
                    nom.textContent = u.nom + (Number(u.utilisateurId) === moiId ? ' (moi)' : '');
                    const role = document.createElement('span');
                    role.className = 'badge text-bg-light ms-auto';
                    role.textContent = rolesNoms[u.role] || '';
                    li.appendChild(puce); li.appendChild(nom); li.appendChild(role);
                    presenceListe.appendChild(li);
                });
            }

            tabs.forEach(t => t.addEventListener('click', () => { if (t.dataset.canal !== canalCourant) chargerSalon(t.dataset.canal); }));

            // Chargement initial du salon par défaut (filet de sécurité indépendant du temps réel).
            chargerSalon(canalCourant);

            const connection = new signalR.HubConnectionBuilder()
                .withUrl(urlHub)
                .withAutomaticReconnect()
                .build();

            connection.on('RecevoirMessage', function (m) {
                if (m.canal === canalCourant) {
                    ajouterMessage(m);
                    // Reste lu tant que le salon est ouvert : on efface le badge du menu.
                    fetch(urlMarquerLu, { headers: { 'Accept': 'application/json' } }).catch(() => { });
                } else if (Number(m.utilisateurId) !== moiId) {
                    pointSalon(m.canal, true);
                }
            });

            connection.on('PresenceMaj', rendrePresence);

            function actif(ok) { input.disabled = !ok; bouton.disabled = !ok; connecte = ok; }

            connection.onreconnecting(() => { actif(false); definirStatut('<i class="bi bi-arrow-repeat me-1"></i>Reconnexion…', 'text-bg-warning'); });
            connection.onreconnected(() => { actif(true); definirStatut('<i class="bi bi-broadcast me-1"></i>En direct', 'text-bg-success'); connection.invoke('DemanderPresence').catch(() => { }); });
            connection.onclose(() => { actif(false); definirStatut('<i class="bi bi-plug me-1"></i>Déconnecté', 'text-bg-danger'); });

            connection.start()
                .then(() => {
                    actif(true);
                    definirStatut('<i class="bi bi-broadcast me-1"></i>En direct', 'text-bg-success');
                    connection.invoke('DemanderPresence').catch(() => { });
                    input.focus();
                })
                .catch(() => { definirStatut('<i class="bi bi-exclamation-triangle me-1"></i>Hors ligne', 'text-bg-danger'); });

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                const texte = input.value.trim();
                if (!texte || !connecte) return;
                bouton.disabled = true;
                connection.invoke('Envoyer', canalCourant, texte)
                    .then(() => { input.value = ''; })
                    .catch(() => { })
                    .finally(() => { bouton.disabled = false; input.focus(); });
            });
        })();
    </script>
}
