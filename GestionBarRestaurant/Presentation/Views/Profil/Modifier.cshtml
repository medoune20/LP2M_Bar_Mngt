@model Domaine.Models.ProfilAcces
@{
    ViewData["Title"] = "Configurer le profil";
    string Niveau(string cle)
    {
        foreach (var part in (Model.Permissions ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=');
            if (kv.Length == 2 && kv[0] == cle) return kv[1].ToUpperInvariant();
        }
        return "";
    }
}
<h1 class="fw-bold mb-4">Profil : @Model.Nom</h1>

<div class="card"><div class="card-body">
    <form asp-action="Modifier" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="row g-3 mb-3">
            <div class="col-md-6"><label class="form-label">Nom du profil</label><input name="nom" value="@Model.Nom" class="form-control" /></div>
            <div class="col-md-6 d-flex align-items-end"><div class="form-check"><input type="checkbox" name="actif" value="true" class="form-check-input" @(Model.Actif ? "checked" : "") /><input type="hidden" name="actif" value="false" /><label class="form-check-label">Profil actif</label></div></div>
        </div>

        <table class="table align-middle">
            <thead><tr><th>Module</th><th class="text-center">Aucun accès</th><th class="text-center">Consulter</th><th class="text-center">Consulter + Modifier</th></tr></thead>
            <tbody>
            @foreach (var (cle, nom) in Domaine.ModulesApp.Liste)
            {
                var niv = Niveau(cle);
                <tr>
                    <td><strong>@nom</strong></td>
                    <td class="text-center"><input type="radio" name="mod_@cle" value="" @(niv == "" ? "checked" : "") /></td>
                    <td class="text-center"><input type="radio" name="mod_@cle" value="C" @(niv == "C" ? "checked" : "") /></td>
                    <td class="text-center"><input type="radio" name="mod_@cle" value="M" @(niv == "M" ? "checked" : "") /></td>
                </tr>
            }
            </tbody>
        </table>

        <div class="mt-3">
            <button class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Retour</a>
        </div>
        <p class="text-muted small mt-2 mb-0">L'administrateur et le super administrateur conservent toujours l'accès complet. Les changements s'appliquent à la prochaine connexion des utilisateurs concernés.</p>
    </form>
</div></div>
