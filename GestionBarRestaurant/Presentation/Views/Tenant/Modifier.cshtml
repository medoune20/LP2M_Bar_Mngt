@model Tenant
@{
    ViewData["Title"] = "Mon établissement";
    var isSuperAdmin = Context.Session.GetString("IsSuperAdmin") == "true";
}
<h1 class="fw-bold mb-4">@(isSuperAdmin ? "Modifier le tenant" : "Mon établissement")</h1>

<div class="card">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <strong>Impossible d'enregistrer :</strong>
                    <div asp-validation-summary="All" class="mb-0"></div>
                </div>
            }
            <input type="hidden" asp-for="Id" />

            <h6 class="fw-bold text-muted mb-3"><i class="bi bi-shop me-1"></i> Identité</h6>
            <div class="row g-3">
                <div class="col-md-6"><label asp-for="Nom" class="form-label"></label><input asp-for="Nom" class="form-control" /><span asp-validation-for="Nom" class="text-danger"></span></div>
                <div class="col-md-3"><label asp-for="Code" class="form-label"></label><input asp-for="Code" class="form-control" /><span asp-validation-for="Code" class="text-danger"></span></div>
                <div class="col-md-3"><label asp-for="CouleurPrincipale" class="form-label">Couleur</label><input asp-for="CouleurPrincipale" type="color" class="form-control form-control-color" /></div>
                <div class="col-md-8"><label asp-for="Slogan" class="form-label"></label><input asp-for="Slogan" class="form-control" placeholder="Ex. : La référence des bonnes soirées" /></div>
                <div class="col-md-4">
                    <label class="form-label">Logo (PNG/JPG)</label>
                    <input type="file" name="logo" accept=".png,.jpg,.jpeg,.webp" class="form-control" />
                    @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
                    {
                        <img src="@(Model.LogoPath.StartsWith("/") ? Url.Content("~" + Model.LogoPath) : Model.LogoPath)" style="height:48px;margin-top:8px;border-radius:6px;" />
                    }
                </div>
            </div>

            <h6 class="fw-bold text-muted mb-3 mt-4"><i class="bi bi-telephone me-1"></i> Coordonnées (factures &amp; pub)</h6>
            <div class="row g-3">
                <div class="col-md-4"><label asp-for="Telephone" class="form-label"></label><input asp-for="Telephone" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="SiteWeb" class="form-label"></label><input asp-for="SiteWeb" class="form-control" placeholder="facebook.com/..., site web" /></div>
                <div class="col-md-8"><label asp-for="Adresse" class="form-label"></label><input asp-for="Adresse" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Ville" class="form-label"></label><input asp-for="Ville" class="form-control" /></div>
            </div>

            <h6 class="fw-bold text-muted mb-3 mt-4"><i class="bi bi-file-earmark-text me-1"></i> Mentions légales (factures)</h6>
            <div class="row g-3">
                <div class="col-md-6"><label asp-for="RegistreCommerce" class="form-label"></label><input asp-for="RegistreCommerce" class="form-control" placeholder="RCCM" /></div>
                <div class="col-md-6"><label asp-for="NumeroContribuable" class="form-label"></label><input asp-for="NumeroContribuable" class="form-control" placeholder="Compte contribuable" /></div>
                <div class="col-12"><label asp-for="PiedFacture" class="form-label"></label><textarea asp-for="PiedFacture" class="form-control" rows="2" placeholder="Merci de votre visite. Les boissons ne sont ni reprises ni échangées."></textarea></div>
            </div>

            @if (isSuperAdmin)
            {
                <div class="col-12 form-check ms-2 mt-3"><input asp-for="Actif" class="form-check-input" /><label asp-for="Actif" class="form-check-label">Tenant actif</label></div>
            }

            <div class="mt-4">
                <button class="btn btn-primary">Enregistrer</button>
                @if (isSuperAdmin)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                }
            </div>
        </form>
    </div>
</div>
