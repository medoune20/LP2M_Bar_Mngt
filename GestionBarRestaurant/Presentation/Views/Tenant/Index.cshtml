@model List<Tenant>
@{
    ViewData["Title"] = "Tenants";
    var isSuperAdmin = Context.Session.GetString("IsSuperAdmin") == "true";
    var tenantId = Context.Session.GetInt32("TenantId") ?? 0;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">Tenants</h1>
        <p class="text-muted mb-0">Gestion des établissements / sociétés.</p>
    </div>
    @if (isSuperAdmin)
    {
        <a asp-action="Nouveau" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Ajouter tenant</a>
    }
</div>

<div class="row g-4">
@foreach (var t in Model)
{
    <div class="col-md-4">
        <div class="card h-100 tenant-card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <h5 class="fw-bold">@t.Nom</h5>
                    <span class="badge @(t.Actif ? "bg-success" : "bg-secondary")">@(t.Actif ? "Actif" : "Inactif")</span>
                </div>
                <div class="text-muted mb-2">@t.Code</div>
                <div class="small">@t.Adresse</div>
                <div class="small">@t.Telephone</div>
                <div class="mt-3 d-flex gap-2">
                    @if (isSuperAdmin)
                    {
                        <form asp-action="Changer" asp-route-id="@t.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm @(tenantId == t.Id ? "btn-success" : "btn-outline-primary")">Utiliser</button>
                        </form>
                        <a asp-action="Modifier" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    }
                </div>
            </div>
        </div>
    </div>
}
</div>
