@model Client
@{
    ViewData["Title"] = "Nouveau client";
}
<h1 class="fw-bold mb-4">Nouveau client</h1>

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <strong>Impossible d'enregistrer :</strong>
                    <div asp-validation-summary="All" class="mb-0"></div>
                </div>
            }
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TenantId" />
            <div class="row g-3">
                <div class="col-md-6"><label asp-for="Nom" class="form-label"></label><input asp-for="Nom" class="form-control" /><span asp-validation-for="Nom" class="text-danger"></span></div>
                <div class="col-md-3"><label asp-for="Telephone" class="form-label"></label><input asp-for="Telephone" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="TypeClient" class="form-label"></label><select asp-for="TypeClient" class="form-select"><option value="@TypeClient.Particulier">Particulier</option><option value="@TypeClient.Entreprise">Entreprise</option><option value="@TypeClient.VIP">VIP</option></select></div>
                <div class="col-md-3"><label asp-for="PlafondCredit" class="form-label">Plafond de crédit</label><input asp-for="PlafondCredit" type="number" step="1" min="0" class="form-control" /><div class="form-text">0 = crédit illimité.</div></div>
                <div class="col-md-3"><label asp-for="PointsFidelite" class="form-label">Points fidélité</label><input asp-for="PointsFidelite" type="number" step="1" class="form-control" /></div>
                <div class="col-md-6"><label asp-for="Adresse" class="form-label"></label><input asp-for="Adresse" class="form-control" /></div>
                <div class="col-12 form-check ms-2"><input asp-for="Actif" class="form-check-input" /><label asp-for="Actif" class="form-check-label">Actif</label></div>
            </div>
            <div class="mt-4"><button class="btn btn-primary">Enregistrer</button><a asp-action="Index" class="btn btn-outline-secondary">Annuler</a></div>
        </form>
    </div>
</div>
