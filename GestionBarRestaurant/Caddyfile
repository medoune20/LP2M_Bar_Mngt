# LP2M - passerelle unique HTTPS pour toutes les applications.
# Caddy gere automatiquement les certificats Let's Encrypt pour lp2medoune.com et www.
# Ne pas lancer Nginx/Certbot sur les ports 80/443 en parallele.
lp2medoune.com, www.lp2medoune.com {
    encode gzip
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }

    # --- LP2M Gestion Bar / Restaurant ---
    # URL publique : https://lp2medoune.com/gestionbar
    # Le prefixe /gestionbar est conserve ; l'application le gere via PATH_BASE=/gestionbar.
    handle /gestionbar* {
        reverse_proxy app:8080
    }

    # --- LP2M Gestion Hopital ---
    # URL publique : https://lp2medoune.com/hopital
    # Le prefixe /hopital est conserve ; l'application le gere via PATH_BASE=/hopital.
    handle /hopital* {
        reverse_proxy host.docker.internal:5050
    }

    # --- Compatibilite anciens liens Hopital ---
    # Safari peut garder une ancienne page dont le formulaire poste vers /Auth/Connexion.
    # Ces routes sont donc redirigees vers /hopital/... avant le fallback GestionBar.
    @hopitalLegacy path /Auth* /Accueil* /Patient* /RendezVous* /Consultation* /Examen* /Hospitalisation* /Departement* /Medecin* /FileAttente* /Paiement* /Comptabilite* /Alerte* /Mail* /Lp2m*
    handle @hopitalLegacy {
        redir /hopital{uri} 302
    }

    # --- Accueil LP2M ---
    handle / {
        redir /gestionbar/ 302
    }

    # Toute autre route revient vers l'accueil LP2M.
    handle {
        redir /gestionbar/ 302
    }
}
