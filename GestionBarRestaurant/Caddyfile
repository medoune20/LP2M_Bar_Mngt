# LP2M - passerelle unique HTTPS pour toutes les applications.
# Caddy gere automatiquement les certificats Let's Encrypt pour lp2medoune.com et www.
# Ne pas lancer Nginx/Certbot sur les ports 80/443 en parallele.
lp2medoune.com, www.lp2medoune.com {
    encode gzip
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }

    # --- Compatibilite anciens liens Hopital ---
    # Important : ces redirections sont placees AVANT les handles principaux.
    # Elles corrigent les anciens liens/formulaires comme /Auth/Connexion
    # qui doivent aller vers /hopital/Auth/Connexion.
    @legacyAuth path /Auth /Auth/*
    redir @legacyAuth /hopital{uri} 302

    @legacyAccueil path /Accueil /Accueil/*
    redir @legacyAccueil /hopital{uri} 302

    @legacyPatient path /Patient /Patient/*
    redir @legacyPatient /hopital{uri} 302

    @legacyRdv path /RendezVous /RendezVous/*
    redir @legacyRdv /hopital{uri} 302

    @legacyHospital path /Consultation /Consultation/* /Examen /Examen/* /Hospitalisation /Hospitalisation/* /Departement /Departement/* /Medecin /Medecin/* /FileAttente /FileAttente/* /Paiement /Paiement/* /Comptabilite /Comptabilite/* /Alerte /Alerte/* /Mail /Mail/* /Lp2m /Lp2m/*
    redir @legacyHospital /hopital{uri} 302

    # --- LP2M Gestion Bar / Restaurant ---
    # URL publique : https://lp2medoune.com/gestionbar
    handle /gestionbar* {
        reverse_proxy app:8080
    }

    # --- LP2M Gestion Hopital ---
    # URL publique : https://lp2medoune.com/hopital
    # Le prefixe /hopital est conserve ; l'application le gere via PATH_BASE=/hopital.
    handle /hopital* {
        reverse_proxy host.docker.internal:5050
    }

    # --- Accueil LP2M ---
    handle / {
        redir /gestionbar/ 302
    }

    # Toute autre route revient vers l'accueil LP2M.
    handle {
        redir /gestionbar/ 302
    }
}
