# Configuration SMTP pour l'envoi d'emails (mot de passe oublié, confirmation d'inscription).
#
# 1. Copiez ce fichier en .env  :  cp .env.example .env
# 2. Renseignez vos vraies valeurs ci-dessous.
# 3. Relancez :  docker compose up -d --build   (ou -f docker-compose.local.yml)
#
# IMPORTANT : le fichier .env contient des secrets et ne doit JAMAIS être versionné
# (il est déjà ignoré par Git).

# ----- Exemple Gmail -----
# Gmail exige un "mot de passe d'application" (et non votre mot de passe habituel) :
#   https://myaccount.google.com/apppasswords  (activez d'abord la validation en 2 étapes)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votreadresse@gmail.com
SMTP_PASS=mot_de_passe_application_16_caracteres
SMTP_FROM=votreadresse@gmail.com
SMTP_SSL=true

# ----- Autres fournisseurs (exemples) -----
# Outlook/Microsoft 365 :  SMTP_HOST=smtp.office365.com   SMTP_PORT=587
# OVH :                    SMTP_HOST=ssl0.ovh.net         SMTP_PORT=587
# Brevo (Sendinblue) :     SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587
