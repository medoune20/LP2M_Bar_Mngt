<Window x:Class="LP2M_Bar_Mngt.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LP2M_Bar_Mngt"
        Width="1380"
        Height="840"
        MinWidth="1160"
        MinHeight="720"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Loaded="OnLoaded">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,24">
                    <TextBlock Text="LP2M" Foreground="White" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Bar Management" Foreground="{StaticResource SidebarMutedBrush}" FontSize="13" Margin="0,2,0,22" />

                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Title}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding Key}"
                                        Style="{StaticResource SidebarButtonStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,24">
                    <TextBlock Text="Standalone SQLite" Foreground="{StaticResource SidebarMutedBrush}" FontSize="12" />
                    <TextBlock Text="Mode hors connexion" Foreground="#EEF5F1" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,22">
                <Button DockPanel.Dock="Right"
                        Content="Actualiser"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />

                <StackPanel>
                    <TextBlock Text="{Binding CurrentModuleTitle}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="{Binding CurrentModuleDescription}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Ventes du jour" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Summary.TodayRevenue, StringFormat={}{0:N2}}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Tickets" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Summary.TodayTicketCount}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Sessions ouvertes" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Summary.OpenCashSessionCount}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Alertes stock" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Summary.LowStockCount}"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1.35*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <TextBlock Text="Actions"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Les boutons ci-dessous executent directement les operations du module."
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CurrentModuleFeatures}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="14"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Details}"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Margin="0,4,20,0" />
                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Margin="0,8,0,0" />
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Content="{Binding ButtonText}"
                                                        Command="{Binding Command}"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Padding="10,8"
                                                        VerticalAlignment="Top" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <TextBlock Text="Donnees du module"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding CurrentModuleStatus}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0" />
                        </StackPanel>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="190" />
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="0"
                                      ItemsSource="{Binding CurrentModuleRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="130" />
                                    <DataGridTextColumn Header="Element" Binding="{Binding Item}" Width="*" />
                                    <DataGridTextColumn Header="Valeur" Binding="{Binding Value}" Width="90" />
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="1.2*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="2"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="Alertes stock faible"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding Summary.LowStockAlerts}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HeadersVisibility="Column"
                                              IsReadOnly="True"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Produit" Binding="{Binding ProductName}" Width="*" />
                                            <DataGridTextColumn Header="Qte" Binding="{Binding Quantity, StringFormat={}{0:N0}}" Width="70" />
                                            <DataGridTextColumn Header="Seuil" Binding="{Binding Threshold, StringFormat={}{0:N0}}" Width="70" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <DockPanel Grid.Row="3" Margin="0,18,0,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Summary.ActiveUserCount, StringFormat={}{0} utilisateur actif}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="12" />
                <TextBlock Text="{Binding DatabasePath}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Grid>
    </Grid>
</Window>
